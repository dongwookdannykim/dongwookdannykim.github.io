@unpublished{kim_authority_theory,
  title        = {Authority without Territory: State Claims of Right in the Global Commons},
  author       = {Kim, Dongwook},
  year         = {2026},
  note         = {Job-market paper candidate; article manuscript in preparation},
  howpublished = {Working paper},
  abstract     = {Why do some state attempts to establish sovereignty-related authority over legally open global commons stabilize as accepted claims of right, while others fail? This paper develops a theory of authority without territory: arrangements in which states claim the right to regulate, identify, appropriate, or exclude in global commons while stopping short of territorial sovereignty and preserving the commons freedoms of others. It argues that such claims stabilize when three conditions interlock: accommodation by powers capable of disruption, resonance in legitimating vocabularies, and constructive ambiguity within a shared framework.},
  bibtex_show  = {true}
}

@unpublished{kim_eez,
  title        = {Sovereign Rights without Sovereignty: The Exclusive Economic Zone and Authority without Territory},
  author       = {Kim, Dongwook},
  year         = {2026},
  note         = {Job-market paper candidate; article manuscript in preparation},
  howpublished = {Working paper},
  abstract     = {The exclusive economic zone is the clearest successful case of authority without territory: a regime in which coastal states exercise extensive sovereign rights over resources and certain activities without holding the seabed and waters as sovereign territory. This paper traces how the EEZ stabilized as an accepted claim of right and uses it to develop the broader account of how authority over the global commons becomes durable.},
  bibtex_show  = {true}
}

